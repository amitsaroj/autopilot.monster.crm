# Production Environment Configuration
# Domain: https://api.autopilot.monster
# Database: Neon PostgreSQL (Managed)

# Application
APP_PORT=8000
APP_HOST=0.0.0.0
APP_URL=https://api.autopilot.monster
NODE_ENV=production
APP_SECRET=autopilot-super-secret-key-2026-prod
LOG_LEVEL=info
LOG_FORMAT=json

# Database (Neon PostgreSQL - Managed)
DATABASE_URL=postgresql://neondb_owner:npg_yIc5F3HCmOQX@ep-proud-sunset-a7wg71xc-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_SYNCHRONIZE=false
DB_SSL=true
DB_LOGGING=false
DB_POOL_SIZE=20

# Cache / Queue (Docker Redis Container)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0
REDIS_TLS=false
REDIS_TTL=3600

# Storage (AWS S3)
MINIO_ENDPOINT=s3.ap-south-1.amazonaws.com
MINIO_PORT=443
MINIO_ACCESS_KEY=dummy_access_key
MINIO_SECRET_KEY=dummy_secret_key

# Vector Database (Docker Qdrant Container)
QDRANT_URL=http://qdrant:6333

# Authentication
JWT_SECRET=jwt-secret-autopilot-monster-crm-2026-secure
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=jwt-refresh-autopilot-monster-crm-2026-secure
JWT_REFRESH_EXPIRES_IN=7d

# AI Services
OPENAI_API_KEY=sk-dummy-openai-key
FRONTEND_URL=https://autopilot.monster

# Stripe
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OAuth Google
GOOGLE_CLIENT_ID=dummy_google_id
GOOGLE_CLIENT_SECRET=dummy_google_secret
GOOGLE_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/google/callback

# OAuth Facebook
FACEBOOK_APP_ID=dummy_facebook_id
FACEBOOK_APP_SECRET=dummy_facebook_secret
FACEBOOK_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/facebook/callback

# OAuth GitHub
