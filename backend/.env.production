# Production Environment Configuration
# Domain: https://api.autopilot.monster
# Database: Neon PostgreSQL (Managed)

# Application
APP_PORT=8000
APP_HOST=0.0.0.0
APP_URL=https://api.autopilot.monster
NODE_ENV=production
APP_SECRET=${PROD_APP_SECRET}
LOG_LEVEL=info
LOG_FORMAT=json

# Database (Neon PostgreSQL - Managed)
DATABASE_URL=postgresql://neondb_owner:npg_yIc5F3HCmOQX@ep-proud-sunset-a7wg71xc-pooler.ap-southeast-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_SYNCHRONIZE=false
DB_SSL=true
DB_LOGGING=false
DB_POOL_SIZE=20

# Cache / Queue (Docker Redis Container)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0
REDIS_TLS=false
REDIS_TTL=3600

# Storage (AWS S3)
MINIO_ENDPOINT=${S3_ENDPOINT}
MINIO_PORT=443
MINIO_ACCESS_KEY=${AWS_S3_ACCESS_KEY}
MINIO_SECRET_KEY=${AWS_S3_SECRET_KEY}

# Vector Database (Docker Qdrant Container)
QDRANT_URL=http://qdrant:6333

# Authentication
JWT_SECRET=${PROD_JWT_SECRET}
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=${PROD_JWT_REFRESH_SECRET}
JWT_REFRESH_EXPIRES_IN=7d

# AI Services
OPENAI_API_KEY=${PROD_OPENAI_API_KEY}
FRONTEND_URL=https://autopilot.monster

# Stripe
STRIPE_SECRET_KEY=${PROD_STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${PROD_STRIPE_WEBHOOK_SECRET}

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OAuth Google
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
GOOGLE_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/google/callback

# OAuth Facebook
FACEBOOK_APP_ID=${FACEBOOK_APP_ID}
FACEBOOK_APP_SECRET=${FACEBOOK_APP_SECRET}
FACEBOOK_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/facebook/callback

# OAuth GitHub
GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}
GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET}
GITHUB_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/github/callback

# OAuth Apple
APPLE_CLIENT_ID=${APPLE_CLIENT_ID}
APPLE_TEAM_ID=${APPLE_TEAM_ID}
APPLE_KEY_ID=${APPLE_KEY_ID}
APPLE_PRIVATE_KEY=${APPLE_PRIVATE_KEY}
APPLE_CALLBACK_URL=https://api.autopilot.monster/api/v1/auth/apple/callback
