{
  "name": "autopilot-monster-crm",
  "version": "1.0.0",
  "description": "AutopilotMonster CRM — Full-Stack AI-Powered CRM Platform",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build",
    "build:all": "turbo run build",
    "dev": "nest start --watch",
    "dev:core": "nest start core --watch",
    "start": "node dist/apps/core/main",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "turbo run typecheck",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "lint:check": "eslint \"{apps,libs}/**/*.ts\"",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest-e2e.config.ts",
    "test:core": "jest --testPathPattern=apps/core",
    "migrate:run": "typeorm migration:run -d apps/core/src/database/data-source.ts",
    "migrate:revert": "typeorm migration:revert -d apps/core/src/database/data-source.ts",
    "migrate:generate": "typeorm migration:generate -d apps/core/src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/platform-fastify": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/bull": "^10.2.1",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/websockets": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.1",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/schedule": "^4.1.1",
    "typeorm": "^0.3.20",
    "pg": "^8.12.0",
    "bull": "^4.16.3",
    "ioredis": "^5.4.1",
    "cache-manager": "^5.7.6",
    "cache-manager-ioredis-yet": "^2.1.1",
    "minio": "^8.0.0",
    "@qdrant/js-client-rest": "^1.11.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "winston": "^3.14.2",
    "nest-winston": "^1.9.7",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/node": "^22.5.5",
    "@types/express": "^4.17.21",
    "@types/uuid": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/multer": "^1.4.12",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/jest": "^29.5.13",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "supertest": "^7.0.0",
    "turbo": "^2.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@autopilot/core/(.*)$": "<rootDir>/apps/core/src/$1",
      "^@autopilot/core$": "<rootDir>/apps/core/src",
      "^@autopilot/auth/(.*)$": "<rootDir>/apps/auth/src/$1",
      "^@autopilot/auth$": "<rootDir>/apps/auth/src"
    }
  }
}
