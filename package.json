{
  "name": "autopilot-monster-crm",
  "version": "1.0.0",
  "description": "AutopilotMonster CRM — Full-Stack AI-Powered CRM Platform",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build",
    "build:all": "turbo run build",
    "build:ui": "npm run build --workspace=apps/ui",
    "dev": "nest start --watch",
    "dev:core": "nest start core --watch",
    "dev:ui": "npm run dev --workspace=apps/ui",
    "dev:all": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue.bold,magenta.bold\" \"nest start --watch\" \"npm run dev --workspace=apps/ui\"",
    "start": "node dist/apps/core/main",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "turbo run typecheck",
    "lint": "eslint \"{apps,libs}/**/*.{ts,tsx}\" --fix",
    "lint:check": "eslint \"{apps,libs}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest-e2e.config.ts",
    "test:core": "jest --testPathPattern=apps/core",
    "migrate:run": "typeorm migration:run -d apps/core/src/database/data-source.ts",
    "migrate:revert": "typeorm migration:revert -d apps/core/src/database/data-source.ts",
    "migrate:generate": "typeorm migration:generate -d apps/core/src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@qdrant/js-client-rest": "^1.17.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.71.0",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nest-winston": "^1.10.2",
    "openai": "^6.32.0",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "twilio": "^5.13.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@next/eslint-plugin-next": "^16.2.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@autopilot/core/(.*)$": "<rootDir>/apps/core/src/$1",
      "^@autopilot/core$": "<rootDir>/apps/core/src",
      "^@autopilot/auth/(.*)$": "<rootDir>/apps/auth/src/$1",
      "^@autopilot/auth$": "<rootDir>/apps/auth/src"
    }
  }
}
