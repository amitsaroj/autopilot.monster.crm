# ============================================================
# AutopilotMonster CRM — Environment Variables Example
# Copy to .env and fill in values before running
# ============================================================

# ----- App -----
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_URL=http://localhost:3000
APP_SECRET=change-me-32-char-secret-key-here

# ----- Database (Postgres) -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autopilot_crm
DB_USER=autopilot
DB_PASSWORD=autopilot_password
DB_SSL=false
DB_LOGGING=false
DB_SYNCHRONIZE=false
DB_POOL_SIZE=10

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_TTL=3600

# ----- MinIO (Object Storage) -----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_ASSETS=autopilot-assets
MINIO_BUCKET_BACKUPS=autopilot-backups

# ----- Qdrant (Vector DB) -----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_CRM=crm-vectors
QDRANT_COLLECTION_AI=ai-vectors

# ----- JWT -----
JWT_SECRET=change-me-jwt-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# ----- Bull / Queue -----
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# ----- SMTP (Notifications) -----
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=autopilot.monster@gmail.com

# ----- Throttle / Rate Limiting -----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ----- Logging -----
LOG_LEVEL=debug
LOG_FORMAT=json

# ----- Sentry (optional) -----
SENTRY_DSN=

# ----- Stripe (Billing) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ----- OpenAI (AI Engine) -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ----- Twilio (Voice/SMS) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ----- WhatsApp (Meta) -----
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
