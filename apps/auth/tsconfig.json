{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/auth",
    "baseUrl": "../../",
    "paths": {
      "@autopilot/core": ["apps/core/src/index.ts"],
      "@autopilot/core/*": ["apps/core/src/*"],
      "@autopilot/auth": ["apps/auth/src/index.ts"],
      "@autopilot/auth/*": ["apps/auth/src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
